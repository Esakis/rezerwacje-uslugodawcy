// BookEasy — model danych (rdzeń wg PLAN.md sekcja 3).
// Lokalnie SQLite; na produkcji zmień provider na "postgresql".
// Enumy i JSON trzymane jako String dla przenośności między SQLite a Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Provider {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  // opcjonalne: konta zakładane przez Google nie mają hasła
  googleId      String?  @unique // logowanie przez Google (sub z id_token)
  avatarUrl     String?  // zdjęcie z konta Google
  slug          String   @unique // adres publiczny: /twoja-nazwa
  name          String
  phone         String?
  // Godziny pracy jako JSON: { "1": [{"from":"09:00","to":"17:00"}], ... } klucz = dzień tygodnia 0-6 (0=niedziela)
  workingHours  String   @default("{}")
  bufferMin     Int      @default(0) // bufor między wizytami (min)
  slotStepMin   Int      @default(15) // granulacja slotów (min)

  // Subskrypcja
  plan          String   @default("trial") // trial | solo | solo_plus | biznes
  trialUntil    DateTime?
  smsSenderName String?  // własna nazwa nadawcy (plan solo_plus+)
  smsUsed       Int      @default(0) // licznik SMS w bieżącym okresie
  smsPeriodStart DateTime @default(now())
  secondReminder Boolean @default(false) // drugie przypomnienie 2h przed (solo_plus+)
  reactivationWeeks Int  @default(0) // SMS „wróć do nas" po X tygodniach od ostatniej wizyty; 0 = wyłączone (solo_plus+)

  // Bramka SMS z telefonu usługodawcy (aplikacja SMS Gate, sms-gate.app).
  // Oba pola ustawione = SMS-y idą najpierw z telefonu (za darmo, poza limitem planu),
  // z fallbackiem na globalną bramkę.
  phoneGwLogin    String?
  phoneGwPassword String?

  // Google Calendar — podłączany osobno w ustawieniach (osobna zgoda niż logowanie Google)
  gcalRefreshToken String?
  gcalEmail        String? // konto Google, z którym połączono kalendarz

  // Stripe Billing (produkcja; w trybie demo bez kluczy pola pozostają puste)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?

  createdAt     DateTime @default(now())

  services      Service[]
  clients       Client[]
  appointments  Appointment[]
  blocks        TimeBlock[]
  smsLogs       SmsLog[]
  staff         StaffMember[]
}

// Osoba, do której umawiana jest wizyta (pracownik salonu).
// Solo-usługodawca ma zwykle jednego. Salon 2-3 osobowy — kilku.
model StaffMember {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name        String
  role        String?  // np. "Barber", "Kosmetolog", "Stylistka rzęs"
  avatarUrl   String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  appointments Appointment[]

  @@index([providerId])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name        String
  durationMin Int
  priceGrosze Int      // cena w groszach (np. 8000 = 80,00 zł)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  appointments Appointment[]

  @@index([providerId])
}

model Client {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name       String
  phone      String   // identyfikator klienta u danego usługodawcy
  notes      String?
  reactivationSentAt DateTime? // kiedy wysłano ostatni SMS „wróć do nas" (żeby nie powtarzać)
  createdAt  DateTime @default(now())

  appointments Appointment[]

  @@unique([providerId, phone]) // deduplikacja po numerze
  @@index([providerId])
}

model Appointment {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  staffId     String?  // do kogo umówiona wizyta (opcjonalne — solo bez pracowników)
  staff       StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  startAt     DateTime // UTC
  endAt       DateTime // UTC
  priceGrosze Int?     // snapshot ceny usługi z momentu rezerwacji (null = starsze wizyty; fallback na bieżącą cenę)
  status      String   @default("booked") // booked | cancelled | no_show | done
  source      String   @default("online") // online | manual
  note        String?
  cancelToken String   @unique @default(cuid()) // do linku odwołania bez logowania
  gcalEventId String?  // wydarzenie w Google Calendar usługodawcy (jeśli kalendarz podłączony)

  // flagi wysłanych SMS (żeby cron nie wysyłał podwójnie)
  confirmSent Boolean  @default(false)
  reminder24Sent Boolean @default(false)
  reminder2Sent  Boolean @default(false)

  createdAt   DateTime @default(now())

  smsLogs     SmsLog[]

  @@index([providerId, startAt])
  @@index([staffId, startAt])
  @@index([status, startAt])
}

// Blokady terminów: urlop, przerwa
model TimeBlock {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  staffId    String?  // blokada konkretnej osoby (null = całego salonu)
  startAt    DateTime // UTC
  endAt      DateTime // UTC
  reason     String?

  @@index([providerId, startAt])
}

model SmsLog {
  id            String   @id @default(cuid())
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  type          String   // confirm | reminder24 | reminder2 | cancel | login | reactivation | owner_new
  phone         String
  body          String
  status        String   // sent | failed | skipped_limit
  costGrosze    Int      @default(0)
  sentAt        DateTime @default(now())

  @@index([providerId, sentAt])
}

// Kod jednorazowy do logowania klienta w panelu klienta (przez SMS).
model LoginCode {
  id        String   @id @default(cuid())
  phone     String   // znormalizowany numer (E.164)
  codeHash  String   // hash 6-cyfrowego kodu
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}
