# BookEasy — konfiguracja środowiska. Skopiuj do .env i uzupełnij.
# Bez opcjonalnych sekcji aplikacja działa lokalnie w trybie demo (mock SMS, plan bez płatności).

# --- Wymagane ---
# Lokalne dev: SQLite. Produkcja: PostgreSQL (Supabase/Neon) — zmień też provider
# w prisma/schema.prisma na "postgresql" i uruchom `prisma db push`.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:haslo@host:5432/bookeasy"

# Publiczny adres aplikacji (linki w SMS-ach, OAuth redirecty, Stripe return URL).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sekret podpisywania sesji (JWT). Na produkcji ustaw długi losowy ciąg!
APP_SECRET="dev-secret"

# Sekret crona przypomnień (Vercel Cron wysyła Authorization: Bearer <CRON_SECRET>).
CRON_SECRET="dev-cron-secret"

# --- SMS ---
# mock = wypisywanie do konsoli (dev). smsapi = realna bramka SMSAPI.pl.
SMS_PROVIDER="mock"
# SMSAPI_TOKEN=""
# SMS_SENDER_NAME="BookEasy"   # domyślna nazwa nadawcy (wymaga rejestracji u operatora)

# --- Google: logowanie + Google Calendar (opcjonalne) ---
# OAuth Client typu "Web" w Google Cloud; authorized redirect URIs:
#   <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
#   <NEXT_PUBLIC_APP_URL>/api/auth/gcal/callback
# Dla kalendarza włącz Google Calendar API w projekcie.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Stripe Billing: płatne plany (opcjonalne; bez kluczy zmiana planu = tryb demo) ---
# 1. Utwórz w dashboardzie Stripe produkty z cenami miesięcznymi PLN dla planów.
# 2. Webhook: <NEXT_PUBLIC_APP_URL>/api/webhooks/stripe
#    (zdarzenia: checkout.session.completed, customer.subscription.deleted).
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_SOLO=""
# STRIPE_PRICE_SOLO_PLUS=""
# STRIPE_PRICE_BIZNES=""
